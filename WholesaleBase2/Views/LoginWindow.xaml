<Window x:Class="WholesaleBase2.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WholesaleBase2.Views"
        mc:Ignorable="d"
      Title="Вход в систему" 
        Width="400" Height="300"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        KeyDown="Window_KeyDown">

    <Border CornerRadius="10" Background="White" Padding="20" BorderBrush="#FFDDDDDD" BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect BlurRadius="15" ShadowDepth="2" Opacity="0.2"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <TextBlock Text="ОПТОВАЯ БАЗА" 
                       FontSize="24" FontWeight="Bold" 
                       Foreground="#5E4B3C" 
                       HorizontalAlignment="Center" 
                       Margin="0,0,0,20"/>

            <StackPanel Grid.Row="1" Margin="0,0,0,15">
                <TextBlock Text="Пользователь:" Margin="0,0,0,5" Foreground="#555555"/>
                <TextBox x:Name="txtUsername" Height="35" Padding="5"/>
            </StackPanel>

            <StackPanel Grid.Row="2" Margin="0,0,0,20">
                <TextBlock Text="Пароль:" Margin="0,0,0,5" Foreground="#555555"/>
                <PasswordBox x:Name="txtPassword" Height="35" Padding="5"/>
            </StackPanel>

            <Button x:Name="BtnLogin" Grid.Row="3" 
                    Content="ВОЙТИ" 
                    Height="40" 
                    Background="#5E4B3C" 
                    Foreground="White" 
                    FontWeight="Bold"
                    Click="BtnLogin_Click_1"/>

            <TextBlock x:Name="txtError" Grid.Row="4" 
                       Text="" 
                       Foreground="Red" 
                       HorizontalAlignment="Center" 
                       VerticalAlignment="Bottom"
                       Margin="0,10,0,0"/>
        </Grid>
    </Border>
</Window>
