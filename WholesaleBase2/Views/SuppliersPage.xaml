<Page x:Class="WholesaleBase2.Views.SuppliersPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:WholesaleBase2.Views"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="SuppliersPage">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Поставщики" FontSize="28" Foreground="Black" 
                   FontWeight="Light" Margin="0,0,0,20"/>

        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,15">
            <Button Content="➕ Добавить" Name="ADDclick" Click="ADDclick_Click"  Width="120" Height="38" Margin="0,0,10,0"/>
            <Button Content="✏️ Изменить" Name="EDITclick" Click="EDITclick_Click"  Width="120" Height="38" Margin="0,0,10,0"/>
            <Button Content="🗑️ Удалить" Name="DELETEclick" Click="DELETEclick_Click"  Width="120" Height="38" Margin="0,0,10,0"/>
            <Button Content="🔄 Обновить" Name="REFRESHclick" Click="REFRESHclick_Click"  Width="120" Height="38"/>
        </StackPanel>

        <DataGrid x:Name="dgSuppliers" Grid.Row="2" AutoGenerateColumns="False">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Binding="{Binding SupplierID}" Width="80"/>
                <DataGridTextColumn Header="Компания" Binding="{Binding CompanyName}" Width="200"/>
                <DataGridTextColumn Header="Контактное лицо" Binding="{Binding ContactPerson}" Width="180"/>
                <DataGridTextColumn Header="Телефон" Binding="{Binding Phone}" Width="150"/>
                <DataGridTextColumn Header="Email" Binding="{Binding Email}" Width="200"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Page>