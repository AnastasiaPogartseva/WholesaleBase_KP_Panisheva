<Window x:Class="WholesaleBase2.Views.ProductWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WholesaleBase2.Views"
        mc:Ignorable="d"
     Title="Товар" 
        Width="600" Height="500"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent">

    <Border CornerRadius="10" Background="White" Padding="20">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock x:Name="txtTitle" Text="Добавление товара" 
                       FontSize="20" FontWeight="SemiBold" 
                       Foreground="#5E4B3C" Margin="0,0,0,20"/>

            <StackPanel Grid.Row="1">
                <TextBlock Text="Наименование:" Margin="0,0,0,5"/>
                <TextBox x:Name="txtProductName" Height="35" Margin="0,0,0,15"/>

                <TextBlock Text="Цена:" Margin="0,0,0,5"/>
                <TextBox x:Name="txtPrice" Height="35" Margin="0,0,0,15"/>

                <TextBlock Text="Количество:" Margin="0,0,0,5"/>
                <TextBox x:Name="txtQuantity" Height="35" Margin="0,0,0,15"/>

                <TextBlock Text="Категория:" Margin="0,0,0,5"/>
                <ComboBox x:Name="cmbCategory" 
          Height="35" 
          DisplayMemberPath="CategoryName" 
          SelectedValuePath="CategoryID"/>
            </StackPanel>

            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
                <Button Content="Сохранить" Name="Saveclick" Click="Saveclick_Click"
                        Width="100" Height="35" Margin="0,0,10,0"/>
                <Button Content="Отмена" Name="Cancelclick" Click="Cancelclick_Click"
                        Width="100" Height="35"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>