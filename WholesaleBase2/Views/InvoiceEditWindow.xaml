<Window x:Class="WholesaleBase2.Views.InvoiceEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WholesaleBase2.Views"
        mc:Ignorable="d"
         Title="Накладная" 
        Width="800" Height="600"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent">

    <Border CornerRadius="10" Background="White" Padding="20">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock x:Name="txtTitle" Text="Создание накладной" 
                       FontSize="20" FontWeight="SemiBold" 
                       Foreground="#5E4B3C" Margin="0,0,0,20"/>

            <!-- Шапка накладной -->
            <Grid Grid.Row="1" Margin="0,0,0,15">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="Номер:" VerticalAlignment="Top" Margin="0,10,10,0"/>
                <TextBox x:Name="txtInvoiceNumber" Grid.Column="1" Height="35" Margin="0,2,20,37"/>

                <TextBlock Grid.Column="2" Text="Дата:" VerticalAlignment="Center" Margin="0,0,10,0"/>
                <DatePicker x:Name="dpInvoiceDate" Grid.Column="3" Height="35"/>

                <TextBlock Grid.Column="0" Text="Клиент:" VerticalAlignment="Top" Margin="0,39,10,0"/>
                <ComboBox x:Name="cmbCustomer" Grid.Column="1" Height="35" Margin="0,36,20,3"
                          DisplayMemberPath="FullName" SelectedValuePath="CustomerID"/>
            </Grid>

            <!-- Таблица товаров -->
            <DataGrid x:Name="dgItems" Grid.Row="2" AutoGenerateColumns="False" 
                      CanUserAddRows="False" CanUserDeleteRows="False"
                      Margin="0,0,0,15">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Товар" Binding="{Binding ProductName}" Width="250" IsReadOnly="True"/>
                    <DataGridTextColumn Header="Количество" Width="100">
                        <DataGridTextColumn.Binding>
                            <Binding Path="Quantity" UpdateSourceTrigger="PropertyChanged"/>
                        </DataGridTextColumn.Binding>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="Цена" Width="100">
                        <DataGridTextColumn.Binding>
                            <Binding Path="Price" UpdateSourceTrigger="PropertyChanged"/>
                        </DataGridTextColumn.Binding>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="Сумма" Binding="{Binding Total, StringFormat={}{0:N2} ₽}" Width="100" IsReadOnly="True"/>
                    <DataGridTemplateColumn Header="Действия" Width="80">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Button Content="✖" Width="30" Height="25" 
                                        Name="RemoveItem"
                                        Click="RemoveItem_Click"
                                        Tag="{Binding}"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>

            <!-- Добавление товара -->
            <Grid Grid.Row="3" Margin="0,0,0,15">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <ComboBox x:Name="cmbProduct" Grid.Column="0" Height="35" Margin="0,0,10,0"
                          DisplayMemberPath="ProductName" SelectedValuePath="ProductID"/>
                <TextBox x:Name="txtQuantity" Grid.Column="1" Width="80" Height="35" Margin="0,0,10,0"/>
                <Button Content="➕ Добавить товар" Grid.Column="1" Width="120" Height="35" Name="AddItem" Click="AddItem_Click" Grid.ColumnSpan="2" Margin="85,0,5,0" FontSize="12"/>
            </Grid>

            <!-- Итого -->
            <Grid Grid.Row="4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="1" Text="Итого:" FontSize="18" FontWeight="Bold" 
                           VerticalAlignment="Top" Margin="0,12,20,0"/>
                <TextBlock x:Name="txtTotalAmount" Grid.Column="1" Text="0 ₽" FontSize="18" 
                           FontWeight="Bold" VerticalAlignment="Top" Margin="80,19,20,0" RenderTransformOrigin="-0.674,-0.206"/>
            </Grid>

            <!-- Кнопки -->
            <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,50,0,0">
                <Button Content="Сохранить" Name="SAVE" Click="SAVE_Click_1"
                        Width="100" Height="35" Margin="0,0,10,0"/>
                <Button Content="Отмена" Name="CANCEL" Click="CANCEL_Click_1"
                        Width="100" Height="35"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
