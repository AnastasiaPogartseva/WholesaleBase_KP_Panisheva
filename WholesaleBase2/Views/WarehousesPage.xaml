<Page x:Class="WholesaleBase2.Views.WarehousesPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:WholesaleBase2.Views"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
       Title="WarehousesPage">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Склады" FontSize="28" Foreground="Black" 
                   FontWeight="Light" Margin="0,0,0,20"/>

        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,15">
            <Button Content="➕ Добавить" Name="Addclick" Click="Addclick_Click"  Width="120" Height="38" Margin="0,0,10,0"/>
            <Button Content="✏️ Изменить" Name="Editclick" Click="Editclick_Click"  Width="120" Height="38" Margin="0,0,10,0"/>
            <Button Content="🗑️ Удалить" Name="Deleteclick" Click="Deleteclick_Click"  Width="120" Height="38" Margin="0,0,10,0"/>
            <Button Content="🔄 Обновить" Name="Refreshclick" Click="Refreshclick_Click"  Width="120" Height="38"/>
        </StackPanel>

        <DataGrid x:Name="dgWarehouses" Grid.Row="2" AutoGenerateColumns="False">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Binding="{Binding WarehouseID}" Width="80"/>
                <DataGridTextColumn Header="Название склада" Binding="{Binding WarehouseName}" Width="200"/>
                <DataGridTextColumn Header="Адрес" Binding="{Binding Address}" Width="300"/>
                <DataGridTextColumn Header="Телефон" Binding="{Binding Phone}" Width="150"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Page>